{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Item",
  "type": "object",
  "required": ["id", "name", "slot", "stats"],
  "properties": {
    "id": { "type": "string" },
    "name": { "type": "string" },
    "slot": { "oneOf": [{ "type": "string" }, { "type": "array" }] },
    "stats": { "type": "object" }
  }
}
